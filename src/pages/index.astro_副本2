---
// 引入全局 CSS（确保 Tailwind 生效）
import '../styles/global.css';
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <title>跨越时空的数字传承</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body class="bg-stone-50 text-stone-800 antialiased font-sans overflow-x-hidden">

  <main class="w-full">

    <section id="sec-1" class="h-screen w-full flex flex-col items-center justify-center bg-[#e8decf]">
      <h1 class="hero-title text-5xl md:text-6xl font-serif mb-6 opacity-0 blur-2xl translate-y-4 tracking-widest text-[#5c4a3d]">从静态之美到流动之韵</h1>
      <p class="hero-subtitle text-xl tracking-[0.3em] opacity-0 blur-xl text-stone-500">以现代前端科技赋能数字纪念馆</p>
    </section>

    <section id="sec-2" class="h-screen w-full flex flex-col items-center justify-center bg-[#1c1917] text-white px-8 relative overflow-hidden">
      <div class="absolute inset-0 opacity-15 pointer-events-none">
        <img src="/old-site.jpg" alt="旧站现状" class="w-full h-full object-cover grayscale blur-md mix-blend-luminosity" />
      </div>
      
      <div class="relative z-10 flex flex-col items-center w-full">
        <h2 class="sec2-title text-4xl font-serif mb-16 opacity-0 blur-xl translate-y-4">性能枷锁，阻断了沉浸</h2>
        
        <div class="flex flex-col gap-8 w-full max-w-3xl text-center">
          <div class="sec2-item opacity-0 blur-lg translate-y-4">
            <h3 class="text-3xl font-serif text-[#e8decf] mb-2">重叠。</h3>
            <p class="text-stone-400 tracking-widest text-sm uppercase">底层框架产生系统负重</p>
          </div>
          <div class="sec2-item opacity-0 blur-lg translate-y-4">
            <h3 class="text-3xl font-serif text-[#e8decf] mb-2">白屏。</h3>
            <p class="text-stone-400 tracking-widest text-sm uppercase">冗余代码阻碍渲染</p>
          </div>
          <div class="sec2-item opacity-0 blur-lg translate-y-4">
            <h3 class="text-3xl font-serif text-[#e8decf] mb-2">断裂。</h3>
            <p class="text-stone-400 tracking-widest text-sm uppercase">跳转卡顿破坏阅读心境</p>
          </div>
        </div>
      </div>
    </section>

    <section id="sec-3" class="h-[120vh] w-full flex flex-col items-center justify-center bg-stone-100 relative overflow-hidden">
      <div class="absolute inset-0 opacity-30 pointer-events-none">
        <img src="/plum-village.jpg" alt="梅村标杆" class="parallax-bg w-full h-full object-cover grayscale mix-blend-multiply" />
      </div>

      <div class="z-10 text-center px-8 relative">
        <h2 class="sec3-title text-5xl font-serif mb-16 opacity-0 blur-xl">宁静，来自绝对的克制</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 max-w-6xl mx-auto">
          <div class="sec3-item opacity-0 blur-md">
            <h3 class="text-xl font-medium mb-4 text-stone-700 tracking-widest">留白呼吸</h3>
          </div>
          <div class="sec3-item opacity-0 blur-md">
            <h3 class="text-xl font-medium mb-4 text-stone-700 tracking-widest">大地质感</h3>
          </div>
          <div class="sec3-item opacity-0 blur-md">
            <h3 class="text-xl font-medium mb-4 text-stone-700 tracking-widest">画册排版</h3>
          </div>
        </div>
      </div>
    </section>

    <section id="sec-4" class="h-screen w-full flex items-center justify-center bg-[#e8decf] relative overflow-hidden px-8">
      <div class="text-center max-w-4xl">
        <h2 class="sec4-title text-5xl font-serif mb-8 opacity-0 blur-xl">Astro 孤岛架构</h2>
        <p class="sec4-p text-stone-600 text-2xl tracking-widest leading-relaxed opacity-0 blur-xl">
          隐形的技术。<br/>只在需要互动的地方，唤醒生命。
        </p>
      </div>
    </section>

    <section id="sec-5" class="h-screen w-full bg-black text-[#e8decf] overflow-hidden relative">
      <div class="horizontal-scroll-container flex w-[300vw] h-full">
        
        <div class="panel w-screen h-full relative flex items-center justify-center">
          <img src="/new-prototype-1.jpg" class="absolute inset-0 w-full h-full object-cover opacity-40 scale-105 transform origin-center" />
          <h2 class="cinematic-text relative z-10 text-5xl md:text-7xl font-serif tracking-widest leading-tight text-center">网页，<br/>不该只是点击。</h2>
        </div>

        <div class="panel w-screen h-full relative flex items-center justify-center">
          <img src="/new-prototype-2.jpg" class="absolute inset-0 w-full h-full object-cover opacity-40 scale-105 transform origin-center" />
          <h2 class="cinematic-text relative z-10 text-5xl md:text-7xl font-serif tracking-widest leading-tight text-center">而应该像时间一样，<br/>缓缓流动。</h2>
        </div>

        <div class="panel w-screen h-full relative flex items-center justify-center">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-0"></div>
          <img src="/new-prototype-3.jpg" class="absolute inset-0 w-full h-full object-cover opacity-50 scale-105 transform origin-center" />
          <h2 class="cinematic-text relative z-10 text-6xl md:text-8xl font-serif tracking-widest text-center mt-32">无缝。<br/>沉浸。</h2>
        </div>

      </div>
    </section>

    <section id="sec-6" class="min-h-screen w-full flex flex-col items-center justify-center bg-stone-100 text-stone-800 py-32 px-8 relative z-10">
      <h2 class="sec6-title text-4xl font-serif mb-16 opacity-0 blur-lg">打造十年免维护的数字磐石</h2>
      
      <div class="sec6-table w-full max-w-5xl bg-white shadow-2xl rounded-xl overflow-hidden opacity-0 blur-md">
        <div class="grid grid-cols-4 bg-stone-200 border-b border-stone-300 text-sm font-bold tracking-wider">
          <div class="p-6 text-stone-500">维度</div>
          <div class="p-6 text-stone-400">第一代 (旧站)</div>
          <div class="p-6 text-stone-400">第二代 (标杆)</div>
          <div class="p-6 bg-[#5c4a3d] text-[#e8decf] relative overflow-hidden">
            <div class="relative z-10">第三代 (新版提案)</div>
            <div class="shine-effect absolute top-0 left-[-100%] w-1/2 h-full bg-white/20 skew-x-[-20deg]"></div>
          </div>
        </div>
        <div class="grid grid-cols-4 border-b border-stone-100 text-stone-600">
          <div class="p-6 font-medium">架构</div>
          <div class="p-6">代码堆叠负重</div>
          <div class="p-6">重型 CMS</div>
          <div class="p-6 bg-[#e8decf]/30 font-bold text-[#5c4a3d]">孤岛精准加载</div>
        </div>
        <div class="grid grid-cols-4 text-stone-600">
          <div class="p-6 font-medium">体验</div>
          <div class="p-6">生硬跳转白屏</div>
          <div class="p-6">常规页面刷新</div>
          <div class="p-6 bg-[#e8decf]/30 font-bold text-[#5c4a3d]">电影级无缝转场</div>
        </div>
      </div>
    </section>

    <section id="sec-7" class="h-screen w-full flex flex-col items-center justify-center bg-[#e8decf] relative overflow-hidden">
      <div class="ceremonial-line w-px h-0 bg-[#5c4a3d] mb-12 opacity-40"></div>
      
      <h2 class="sec7-title text-5xl md:text-7xl font-serif text-[#5c4a3d] mb-6 opacity-0 blur-lg">跨越时空的数字传承</h2>
      <p class="sec7-subtitle text-xl text-stone-600 tracking-[0.4em] mb-16 opacity-0 blur-md uppercase">A Digital Legacy</p>
      
      <button class="sec7-btn opacity-0 blur-md px-12 py-5 bg-[#5c4a3d] text-[#e8decf] rounded-full text-lg hover:bg-stone-800 transition-all duration-700 tracking-widest cursor-pointer">
        确认蓝图 · 正式启航
      </button>
    </section>

  </main>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Lenis from '@studio-freight/lenis';

    gsap.registerPlugin(ScrollTrigger);

    // --- 1. 初始化 Lenis 平滑滚动 (电影感的核心) ---
    const lenis = new Lenis({
      duration: 1.5, // 拉长滚动时间，增加物理重量感
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // 极其平滑的衰减曲线
      smooth: true,
    });

    // 绑定 Lenis 和 GSAP Ticker
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);

    // --- 全局动画设置：极其克制、缓慢、带对焦效果 ---
    const EASE_CINEMATIC = "sine.inOut";

    // 第一幕：序幕对焦
    window.addEventListener("DOMContentLoaded", () => {
      gsap.to(".hero-title", {
        opacity: 1, y: 0, filter: "blur(0px)",
        duration: 3, ease: EASE_CINEMATIC, delay: 0.2
      });
      gsap.to(".hero-subtitle", {
        opacity: 1, filter: "blur(0px)",
        duration: 3, ease: EASE_CINEMATIC, delay: 0.8
      });
    });

    // 第二幕：痛点 (像回声一样慢慢浮现)
    gsap.to(".sec2-title", {
      scrollTrigger: { trigger: "#sec-2", start: "top 60%" },
      opacity: 1, y: 0, filter: "blur(0px)", duration: 2.5, ease: EASE_CINEMATIC
    });
    gsap.to(".sec2-item", {
      scrollTrigger: { trigger: "#sec-2", start: "top 40%" },
      opacity: 1, y: 0, filter: "blur(0px)", duration: 2, stagger: 0.6, ease: EASE_CINEMATIC
    });

    // 第三幕：梅村标杆视差与对焦
    gsap.to(".parallax-bg", {
      scrollTrigger: { trigger: "#sec-3", start: "top bottom", end: "bottom top", scrub: true },
      y: 150, ease: "none"
    });
    gsap.to(".sec3-title", {
      scrollTrigger: { trigger: "#sec-3", start: "top 60%" },
      opacity: 1, filter: "blur(0px)", duration: 2.5, ease: EASE_CINEMATIC
    });
    gsap.to(".sec3-item", {
      scrollTrigger: { trigger: "#sec-3", start: "top 50%" },
      opacity: 1, filter: "blur(0px)", duration: 2, stagger: 0.3, ease: EASE_CINEMATIC
    });

    // 第四幕：破晓
    gsap.to(".sec4-title, .sec4-p", {
      scrollTrigger: { trigger: "#sec-4", start: "top 60%" },
      opacity: 1, filter: "blur(0px)", duration: 2.5, stagger: 0.4, ease: EASE_CINEMATIC
    });

    // 第五幕：电影级全屏横向画卷
    const panels = gsap.utils.toArray(".panel");
    gsap.to(".horizontal-scroll-container", {
      xPercent: -100 * (panels.length - 1),
      ease: "none",
      scrollTrigger: {
        trigger: "#sec-5",
        pin: true,
        scrub: 1.5, // 擦除延迟增加，让横滑更有惯性
        end: "+=3000" // 需要滚得更久，留给观众欣赏画面的时间
      }
    });
    // 让画卷里的背景图在滚动时产生极其微弱的视差放大
    panels.forEach((panel) => {
      gsap.to(panel.querySelector("img"), {
        scale: 1,
        ease: "none",
        scrollTrigger: {
          trigger: panel,
          containerAnimation: gsap.getById("horizontal"), // 绑定横向滚动
          start: "left right",
          end: "right left",
          scrub: true
        }
      });
    });

    // 第六幕：图穷匕见
    const sec6Tl = gsap.timeline({ scrollTrigger: { trigger: "#sec-6", start: "top 60%" } });
    sec6Tl.to(".sec6-title, .sec6-table", {
      opacity: 1, filter: "blur(0px)", duration: 2, stagger: 0.3, ease: EASE_CINEMATIC
    })
    .to(".shine-effect", { left: "200%", duration: 1.5, ease: "power2.inOut" }, "-=0.5");

    // 第七幕：圆满收盘
    const sec7Tl = gsap.timeline({ scrollTrigger: { trigger: "#sec-7", start: "top 50%" } });
    sec7Tl.to(".ceremonial-line", { height: "150px", duration: 2.5, ease: EASE_CINEMATIC })
    .to(".sec7-title, .sec7-subtitle, .sec7-btn", {
      opacity: 1, filter: "blur(0px)", duration: 2.5, stagger: 0.5, ease: EASE_CINEMATIC
    }, "-=1");

  </script>
</body>
</html>