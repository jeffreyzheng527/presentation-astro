---
import '../styles/global.css';
---

<html lang="zh">
<head>
  <meta charset="utf-8" />
  <title>跨越时空的数字传承</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body class="bg-[#0a0a0a] text-stone-300 antialiased font-sans overflow-x-hidden selection:bg-[#5c4a3d] selection:text-[#e8decf]">

  <svg class="pointer-events-none fixed inset-0 z-50 h-full w-full opacity-[0.12] mix-blend-overlay">
    <filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="3" stitchTiles="stitch" /></filter>
    <rect width="100%" height="100%" filter="url(#noise)" />
  </svg>

  <div class="fixed inset-0 pointer-events-none z-50 overflow-hidden mix-blend-screen">
    <div class="ambient-fog absolute -top-[50%] -left-[50%] w-[200%] h-[200%] bg-[radial-gradient(circle_at_center,rgba(232,222,207,0.015)_0%,transparent_50%)]"></div>
    
    <div class="dust-particles absolute inset-0"></div>
  </div>

  <main class="w-full">

    <audio id="ambient-sound" loop preload="auto">
      <source src="/ambient.mp3" type="audio/mpeg">
    </audio>

    <div id="entrance-veil" class="fixed inset-0 z-[100] bg-[#0a0a0a] flex items-center justify-center cursor-pointer transition-opacity duration-[3000ms]">
      <p class="text-stone-600 tracking-[0.5em] text-sm uppercase animate-pulse">Click to enter the space</p>
    </div>

    <section id="sec-1" class="h-screen w-full flex flex-col items-center justify-center bg-[#0a0a0a] relative">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(232,222,207,0.03)_0%,transparent_70%)]"></div>
      <h1 class="hero-title text-[12vw] leading-none font-serif opacity-0 blur-2xl text-[#e8decf]">流动。</h1>
      <p class="hero-subtitle text-xs tracking-[1em] mt-12 opacity-0 blur-xl text-stone-500 uppercase">A Digital Sanctuary</p>
    </section>

    <section class="h-[40vh] w-full bg-[#0a0a0a] flex justify-center items-center">
      <div class="w-[1px] h-32 bg-stone-800 opacity-50"></div>
    </section>

    <section id="sec-2" class="min-h-screen w-full flex flex-col items-center justify-center relative overflow-hidden py-32">
      <div class="absolute inset-0 opacity-40 pointer-events-none z-0">
        <img src="/old-site.jpg" class="w-full h-full object-cover grayscale blur-sm" />
        <div class="absolute inset-0 bg-[#0a0a0a]/60"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-4xl px-8">
        <div class="sec2-item mb-32 opacity-0 blur-xl translate-y-8">
          <h3 class="text-[8vw] leading-none font-serif text-[#5c4a3d]">重叠</h3>
          <p class="text-sm tracking-widest text-stone-400 mt-4 ml-2">底层的负重，让数字的生命逐渐沉睡。</p>
        </div>
        <div class="sec2-item mb-32 opacity-0 blur-xl translate-y-8 text-right">
          <h3 class="text-[8vw] leading-none font-serif text-stone-500">断裂</h3>
          <p class="text-sm tracking-widest text-stone-400 mt-4 mr-2">每一次白屏的等待，都是对宁静的打扰。</p>
        </div>
      </div>
    </section>

    <section class="h-[50vh] w-full bg-[#0a0a0a] relative overflow-hidden flex justify-center items-center">
       <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] to-stone-100"></div>
    </section>

    <section id="sec-3" class="h-[150vh] w-full flex flex-col items-center justify-center bg-stone-100 relative overflow-hidden">
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <img src="/plum-village.jpg" class="parallax-bg w-full h-[120%] object-cover grayscale mix-blend-multiply" />
      </div>

      <div class="z-10 text-center px-8 relative mix-blend-difference text-stone-200">
        <h2 class="sec3-title text-[8vw] leading-tight font-serif opacity-0 blur-2xl">克制即是<br/>无限</h2>
      </div>
    </section>

    <section id="sec-5" class="h-screen w-full bg-[#0a0a0a] overflow-hidden relative">
      <div class="horizontal-scroll-container flex w-[300vw] h-full">
        
        <div class="panel w-screen h-full relative flex flex-col justify-center overflow-hidden">
          <img src="/new-prototype-1.jpg" class="absolute inset-0 w-full h-full object-cover opacity-10 mix-blend-luminosity scale-125 origin-bottom-left" />
          <h2 class="cinematic-text absolute -left-12 top-24 text-[40vw] font-serif leading-none text-transparent [-webkit-text-stroke:2px_rgba(232,222,207,0.15)] select-none pointer-events-none">网</h2>
          <div class="relative z-10 px-32 mt-32">
             <h3 class="text-3xl font-serif text-[#e8decf] tracking-widest mb-4">不该只是点击。</h3>
             <p class="text-stone-600 tracking-[0.3em] uppercase text-xs">A Space Beyond Interactions</p>
          </div>
        </div>

        <div class="panel w-screen h-full relative flex items-center justify-end px-32 overflow-hidden">
          <img src="/new-prototype-2.jpg" class="absolute inset-0 w-full h-full object-cover opacity-15 mix-blend-overlay scale-125 origin-top-right" />
          <h2 class="cinematic-text absolute -right-12 bottom-12 text-[40vw] font-serif leading-none text-transparent [-webkit-text-stroke:2px_rgba(232,222,207,0.15)] select-none pointer-events-none">页</h2>
          <div class="relative z-10 text-right">
             <h3 class="text-3xl font-serif text-[#e8decf] tracking-widest mb-4">而是时间的无声流淌。</h3>
             <p class="text-stone-600 tracking-[0.3em] uppercase text-xs">Continuity of the mind</p>
          </div>
        </div>

        <div class="panel w-screen h-full relative flex items-center justify-center">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#0a0a0a_80%)] z-10"></div>
          <img src="/new-prototype-3.jpg" class="absolute inset-0 w-full h-full object-cover opacity-20 scale-110 origin-center" />
          <h2 class="relative z-20 text-[5vw] font-serif tracking-[0.5em] text-[#e8decf] opacity-80 mix-blend-screen drop-shadow-2xl">隐于无形</h2>
        </div>

      </div>
    </section>

    <section class="h-[40vh] w-full bg-[#0a0a0a]"></section>

    <section id="sec-6" class="h-screen w-full bg-[#0a0a0a] relative overflow-hidden">
        
        <div class="era-1 absolute inset-0 flex items-center justify-center z-10 bg-[#0a0a0a] px-8 md:px-24">
          <div class="w-full max-w-7xl flex flex-col md:flex-row items-center justify-between gap-16 md:gap-32">
            <div class="w-full md:w-3/5 aspect-video overflow-hidden rounded-sm opacity-60 shadow-2xl relative border border-white/10">
              <img src="/old-site.jpg" class="w-full h-full object-cover grayscale" alt="旧站" />
            </div>
            <div class="w-full md:w-2/5 text-left">
              <h2 class="text-5xl font-serif text-[#e8decf] tracking-widest drop-shadow-lg">第一代</h2>
              <h3 class="text-2xl font-serif text-stone-500 mt-4 tracking-widest">沉重的巨石</h3>
              <div class="w-8 h-[1px] bg-stone-700 my-8"></div>
              <p class="text-stone-400 tracking-[0.2em] text-sm uppercase leading-loose">代码堆叠的负重<br/>让数字生命逐渐沉睡</p>
            </div>
          </div>
        </div>
        
        <div class="era-2 absolute inset-0 flex items-center justify-center z-20 bg-[#0a0a0a] opacity-0 translate-y-12 px-8 md:px-24">
          <div class="w-full max-w-7xl flex flex-col md:flex-row-reverse items-center justify-between gap-16 md:gap-32">
            <div class="w-full md:w-3/5 aspect-video overflow-hidden rounded-sm opacity-70 shadow-2xl relative border border-white/10">
              <img src="/plum-village.jpg" class="w-full h-full object-cover grayscale mix-blend-luminosity" alt="梅村标杆" />
            </div>
            <div class="w-full md:w-2/5 text-right">
              <h2 class="text-5xl font-serif text-[#e8decf] tracking-widest drop-shadow-lg">第二代</h2>
              <h3 class="text-2xl font-serif text-stone-500 mt-4 tracking-widest">仍被页面束缚</h3>
              <div class="w-8 h-[1px] bg-stone-700 my-8 ml-auto"></div>
              <p class="text-stone-400 tracking-[0.2em] text-sm uppercase leading-loose">传统 CMS 的物理跳转<br/>打断了每一次宁静流转</p>
            </div>
          </div>
        </div>

        <div class="era-3 absolute inset-0 flex flex-col items-center justify-center z-30 bg-[#0a0a0a] opacity-0 translate-y-12">
           <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(232,222,207,0.08)_0%,transparent_60%)] pointer-events-none"></div>
           <h2 class="text-6xl md:text-8xl font-serif text-[#e8decf] tracking-[0.3em] mb-8 drop-shadow-2xl">Astro 孤岛架构</h2>
           <p class="text-[#5c4a3d] tracking-[0.3em] uppercase text-xl">体验，终于消失于技术本身。</p>
        </div>

    </section>

    <section id="sec-7" class="h-screen w-full flex flex-col items-center justify-center bg-[#0a0a0a] relative overflow-hidden">
      <div class="ceremonial-line w-[1px] h-0 bg-stone-700 mb-16"></div>
      <button class="sec7-btn opacity-0 blur-md px-12 py-5 bg-transparent border border-stone-700 text-stone-400 rounded-full text-xs hover:bg-stone-800 hover:text-[#e8decf] transition-all duration-1000 tracking-[0.4em] uppercase">
        进入数字空间
      </button>
    </section>

  </main>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Lenis from '@studio-freight/lenis';

    gsap.registerPlugin(ScrollTrigger);

    // ==========================================
    // 0. 【新补上的代码】统一全局动作系统
    // ==========================================
    const MOTION = {
      slow: 3.5,     // 极其缓慢的电影级时间
      medium: 2.0,   // 标准叙事时间
      ease: "sine.inOut" // 无机械感的呼吸曲线
    };

    // ==========================================
    // 1. 初始化 Lenis
    // ==========================================
    const lenis = new Lenis({
      duration: 2.0, 
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smooth: true,
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    // ==========================================
    // 2. 动态重力引擎 (Variable Physics)
    // ==========================================
    ScrollTrigger.create({
      trigger: "#sec-2",
      start: "top center",
      end: "bottom center",
      onEnter: () => lenis.options.duration = 3.5, 
      onLeave: () => lenis.options.duration = 2.0, 
      onEnterBack: () => lenis.options.duration = 3.5,
      onLeaveBack: () => lenis.options.duration = 2.0
    });

    ScrollTrigger.create({
      trigger: "#sec-5",
      start: "top center",
      end: "bottom center",
      onEnter: () => lenis.options.duration = 1.0, 
      onLeave: () => lenis.options.duration = 2.0,
      onEnterBack: () => lenis.options.duration = 1.0,
      onLeaveBack: () => lenis.options.duration = 2.0
    });

    // ==========================================
    // 3. 声音与空间入口系统 (修复版开场)
    // ==========================================
    const veil = document.getElementById('entrance-veil');
    const ambientSound = document.getElementById('ambient-sound');

    // 只有在点击屏幕后，才开始播放声音和浮现文字
    veil.addEventListener('click', () => {
        // 渐隐黑色的帷幕
        veil.style.opacity = '0';
        setTimeout(() => veil.style.display = 'none', 3000);
        
        // 尝试播放低频空间音 (如果你还没有放 ambient.mp3，这里可能会在控制台有个小警告，但不影响画面)
        if(ambientSound) {
            ambientSound.volume = 0;
            let playPromise = ambientSound.play();
            if (playPromise !== undefined) {
                playPromise.then(_ => {
                    gsap.to(ambientSound, { volume: 0.3, duration: 5, ease: "none" });
                }).catch(error => {
                    console.log("音频播放被拦截或文件不存在，但不影响视觉表现。");
                });
            }
        }
        
        // 真正触发第一幕的对焦动画
        gsap.to(".hero-title", { opacity: 1, filter: "blur(0px)", duration: 3, ease: "sine.inOut" });
        gsap.to(".hero-subtitle", { opacity: 1, filter: "blur(0px)", duration: 3, ease: "sine.inOut", delay: 1 });
    });

    // ==========================================
    // 4. 其他章节的 GSAP 动画逻辑
    // ==========================================
    
    // --- 痛点：深渊里的回音 ---
    gsap.utils.toArray(".sec2-item").forEach((item: any, i) => {
      gsap.to(item, {
        scrollTrigger: { trigger: item, start: "top 75%" },
        opacity: 1, y: 0, filter: "blur(0px)", duration: MOTION.slow, ease: MOTION.ease
      });
    });

    // --- 梅村标杆：仰望感 ---
    gsap.to(".parallax-bg", {
      scrollTrigger: { trigger: "#sec-3", start: "top bottom", end: "bottom top", scrub: true },
      y: 200, ease: "none"
    });
    gsap.to(".sec3-title", {
      scrollTrigger: { trigger: "#sec-3", start: "top 60%" },
      opacity: 1, filter: "blur(0px)", duration: MOTION.slow, ease: MOTION.ease
    });

    // --- 横向画卷：空间漫游 ---
    const panels = gsap.utils.toArray(".panel");
    gsap.to(".horizontal-scroll-container", {
      xPercent: -100 * (panels.length - 1),
      ease: "none",
      scrollTrigger: {
        trigger: "#sec-5", pin: true, scrub: 2, end: "+=4000" 
      }
    });
    panels.forEach((panel: any) => {
      gsap.to(panel.querySelector("img"), {
        scale: 1, ease: "none",
        scrollTrigger: {
          trigger: panel, containerAnimation: gsap.getById("horizontal"),
          start: "left right", end: "right left", scrub: true
        }
      });
    });

    // --- 第六幕：三代文明更迭 (画廊错位版) ---
    const sec6Tl = gsap.timeline({
      scrollTrigger: { trigger: "#sec-6", start: "top top", end: "+=3000", scrub: 1, pin: true }
    });
    
    gsap.to(".era-1 img", { scale: 1.1, ease: "none", scrollTrigger: { trigger: "#sec-6", start: "top top", end: "+=3000", scrub: true } });
    gsap.to(".era-2 img", { scale: 1.1, ease: "none", scrollTrigger: { trigger: "#sec-6", start: "top top", end: "+=3000", scrub: true } });

    sec6Tl
      .to(".era-1", { opacity: 0, filter: "blur(15px)", y: -50, duration: 1 })
      .to(".era-2", { opacity: 1, y: 0, filter: "blur(0px)", duration: 1 }, "-=0.5")
      .to(".era-2", { opacity: 1, duration: 0.5 }) 
      .to(".era-2", { opacity: 0, filter: "blur(15px)", y: -50, duration: 1 })
      .to(".era-3", { opacity: 1, y: 0, filter: "blur(0px)", duration: 1.5 }, "-=0.5");

    // --- 终章：仪式感 ---
    const sec7Tl = gsap.timeline({ scrollTrigger: { trigger: "#sec-7", start: "top 60%" } });
    sec7Tl.to(".ceremonial-line", { height: "20vh", duration: MOTION.slow, ease: MOTION.ease })
          .to(".sec7-btn", { opacity: 1, filter: "blur(0px)", duration: MOTION.medium, ease: MOTION.ease }, "-=1.5");

</script>
  
</body>
</html>